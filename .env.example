# Hellobooks AI — Environment Configuration
# Copy to .env and fill in your values. Never commit .env.

# Required
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LLM Settings
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.2

# Embedding Settings
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Retrieval Settings
TOP_K=3
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# API Server
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
